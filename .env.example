# Окружение: test | preprod | prod
ENVIRONMENT=test

POSTGRES_DB=med_ear
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Обязателен для preprod/prod (сервер не запустится без него в prod)
# DJANGO_SECRET_KEY=your-secret-key-min-50-chars

# DEBUG=True для test/preprod, всегда False для prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx

CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Rate limit на auth endpoints (формат: кол-во/период, напр. 5/m, 10/h)
AUTH_RATE_LIMIT=5/m
